.git
**/__pycache__
**/*.pyc
.pytest_cache
.env

# generated artifacts -- never needed in the image
results/
*.md

# test / audit / temp directories -- must NEVER enter the image
# (local outputs contain results.json files: shipping them would look like
# cached answers to the AMD judge)
.local_*/
tmp_*/
freeze_*/
audit_snapshots/
tests/
.github/
